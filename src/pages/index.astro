---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import QuoteForm from '../components/QuoteForm.astro';
import content from '../data/content.json';
const { readySection, bestServices, darkServices, helpSection, business } = content;
---

<MainLayout title="ReliableFix Handyman Services | Rochester, NY">

  <!-- 1. HERO + FLOATING CARDS -->
  <Hero />

  <!-- Spacer: floating cards need space below them -->
  <div style="padding-top: 80px; background:#fff;"></div>

  <!-- 2. READY & WAITING TO ASSIST -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: text -->
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">
            {readySection.eyebrow}
          </p>
          <h2 class="text-4xl font-bold text-gray-900 mb-8 leading-tight">
            {readySection.title}
          </h2>
          <ul class="space-y-5">
            {readySection.bullets.map((bullet) => (
              <li class="flex items-start gap-4">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#F2A93B;">
                  <svg class="w-3 h-3" fill="none" stroke="black" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                </div>
                <span class="text-base leading-relaxed text-gray-600">{bullet}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: image handyman belt -->
        <div class="overflow-hidden">
          <img
            src={readySection.image}
            alt="Handyman with tools"
            class="w-full h-full object-cover"
            style="min-height:360px; object-position:center; background:#e5e7eb;"
            onerror="this.style.background='#e5e7eb'"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- 3. BEST SERVICES IN TOWN (reversed: image left, text right) -->
  <section class="py-20" style="background:#f5f5f5;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: image woodworking -->
        <div class="overflow-hidden">
          <img
            src={bestServices.image}
            alt="Best handyman services"
            class="w-full object-cover"
            style="min-height:400px; object-position:center; background:#e5e7eb;"
            onerror="this.style.background='#e5e7eb'"
          />
        </div>

        <!-- Right: text block -->
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">
            OUR EXPERTISE
          </p>
          <h2 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">
            {bestServices.title}
          </h2>
          <p class="text-base leading-relaxed text-gray-500 mb-8">
            {bestServices.description}
          </p>
          <a
            href={bestServices.ctaHref}
            style="background:#F2A93B;"
            class="inline-block text-black font-bold text-sm px-8 py-4 hover:brightness-95 transition-all"
          >
            {bestServices.cta}
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. DARK SERVICES GRID -->
  <section class="py-20" style="background:#0f0f0f;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">

      <div class="text-center mb-14">
        <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-3">WHAT WE DO</p>
        <h2 class="text-4xl font-bold text-white">Our Services</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {darkServices.map((svc) => (
          <div
            class="p-6 flex flex-col gap-4 hover:shadow-lg transition-all duration-200 cursor-pointer"
            style="border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04);"
          >
            <!-- Icon -->
            <div class="w-12 h-12 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
              {svc.icon === 'wrench' && (
                <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852Z"/>
                </svg>
              )}
              {svc.icon === 'droplet' && (
                <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.444 5.332-6 8.17-6 11a6 6 0 0012 0c0-2.83-1.556-5.668-6-11z"/>
                </svg>
              )}
              {svc.icon === 'brush' && (
                <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
                </svg>
              )}
              {svc.icon === 'hammer' && (
                <svg class="w-6 h-6" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
                </svg>
              )}
            </div>
            <h3 class="text-2xl font-semibold text-white">{svc.title}</h3>
            <p class="text-base leading-relaxed text-gray-400">{svc.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- 5. HELP SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: title + feature boxes -->
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">
            HIGHLY EXPERIENCED HANDYMEN
          </p>
          <h2 class="text-4xl font-bold text-gray-900 mb-4 leading-tight">
            {helpSection.title}
          </h2>
          <p class="text-base leading-relaxed text-gray-500 mb-8">
            {helpSection.description}
          </p>
          <div class="space-y-4">
            {helpSection.features.map((feat) => (
              <div
                class="flex items-start gap-4 p-5"
                style="border: 1px solid #e5e7eb;"
              >
                <div class="w-8 h-8 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
                  {feat.icon === 'shield' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
                    </svg>
                  )}
                  {feat.icon === 'certificate' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
                    </svg>
                  )}
                  {feat.icon === 'clock' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  )}
                </div>
                <p class="text-base leading-relaxed text-gray-600">{feat.text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: technician image -->
        <div class="overflow-hidden">
          <img
            src={helpSection.image}
            alt="Technician at work"
            class="w-full object-cover"
            style="min-height:420px; object-position:center; background:#e5e7eb;"
            onerror="this.style.background='#e5e7eb'"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- 6. TESTIMONIALS -->
  <Testimonials />

  <!-- 7. QUOTE FORM -->
  <QuoteForm />

</MainLayout>
