---
import MainLayout from '../layouts/MainLayout.astro';
import content from '../data/content.json';
const { business, stats, certifications, helpSection, about } = content;
---

<MainLayout title="About Us | ReliableFix Handyman Rochester NY">

  <!-- HERO BANNER: yellow background -->
  <div style="background:#F2A93B; padding-top:120px;" class="pb-0">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 pb-10 text-center">
      <h1 class="text-5xl font-bold tracking-tight text-black">About Us</h1>
    </div>
    <!-- Wave divider -->
    <div style="overflow:hidden; line-height:0;">
      <svg viewBox="0 0 1200 80" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
        <path d="M0,40 C200,80 400,0 600,40 C800,80 1000,0 1200,40 L1200,80 L0,80 Z" fill="#ffffff"/>
      </svg>
    </div>
  </div>

  <!-- HONESTY INTEGRITY EXPERIENCE -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-3">GET TO KNOW US</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Honesty, Integrity & Experience</h2>
        <p class="text-base leading-relaxed text-gray-500 max-w-2xl mx-auto">
          ReliableFix started in 2014 with one goal: Rochester homeowners deserve a handyman service that shows up on time, charges a fair price, and does the job right. Every technician is licensed, insured, and background-checked.
        </p>
      </div>

      <!-- Image banner with testimonial overlay -->
      <div class="relative overflow-hidden" style="height:360px;">
        <div
          class="absolute inset-0 bg-cover bg-center"
          style={`background-color:#2a2a2a; background-image:url('${about.bannerImage}');`}
        ></div>
        <div class="absolute inset-0" style="background:rgba(0,0,0,0.55);"></div>
        <!-- Overlay stat -->
        <div class="absolute inset-0 flex items-center px-10 lg:px-20">
          <div class="text-white">
            <p class="text-8xl font-bold leading-none" style="color:#F2A93B;">100%</p>
            <p class="text-2xl font-semibold mt-2">Satisfaction Guaranteed</p>
          </div>
          <div class="ml-auto max-w-sm hidden lg:block">
            <p class="text-white text-lg italic leading-relaxed">
              "We received the best services we could hope for!"
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT STORY: 2-col image left, text right -->
  <section class="py-20" style="background:#f5f5f5;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: 2x2 service thumbnails -->
        <div class="grid grid-cols-2 gap-4">
          {about.serviceImages.map((svc) => (
            <div class="overflow-hidden">
              <img
                src={svc.src}
                alt={svc.label}
                class="w-full object-cover"
                style="height:200px; background:#e5e7eb;"
                onerror="this.style.background='#e5e7eb'"
              />
              <div class="bg-white p-4">
                <h3 class="text-2xl font-semibold text-gray-900 mb-1">{svc.label}</h3>
                <a href={`/services#${svc.id}`} style="background:#F2A93B;" class="inline-block text-black font-bold text-xs px-4 py-2 mt-1 hover:brightness-95">
                  Read More
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: text -->
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">OUR STORY</p>
          <h2 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">
            Built on Trust Since {business.founded}
          </h2>
          <p class="text-base leading-relaxed text-gray-500 mb-4">
            What began as a one-man operation has grown into Rochester's most trusted multi-trade handyman team — entirely through referrals from homeowners who trusted us with one job and called us back for every job after.
          </p>
          <p class="text-base leading-relaxed text-gray-500 mb-8">
            Today we serve Rochester, Irondequoit, Brighton, Webster, Greece, Fairport, and surrounding Monroe County communities. Locally owned. Background-checked. Licensed and insured.
          </p>
          <a
            href="/contact"
            style="border:2px solid #F2A93B;"
            class="inline-block text-black font-bold text-sm px-8 py-4 hover:bg-yellow-50 transition-all"
          >
            Get in Touch for a Free Quote
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- DARK: WE'RE HERE TO HELP -->
  <section class="py-20" style="background:#0f0f0f;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: title + feature boxes -->
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">
            HIGHLY EXPERIENCED HANDYMEN
          </p>
          <h2 class="text-4xl font-bold text-white mb-4 leading-tight">
            {helpSection.title}
          </h2>
          <p class="text-base leading-relaxed text-gray-400 mb-8">{helpSection.description}</p>
          <div class="space-y-4">
            {helpSection.features.map((feat) => (
              <div class="flex items-start gap-4 p-5" style="border:1px solid rgba(255,255,255,0.1);">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#F2A93B;">
                  <svg class="w-3 h-3" fill="none" stroke="black" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                </div>
                <p class="text-base leading-relaxed text-gray-300">{feat.text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image -->
        <div class="overflow-hidden">
          <img
            src={helpSection.image}
            alt="Technician at work"
            class="w-full object-cover"
            style="min-height:400px; object-position:center; background:#2a2a2a;"
            onerror="this.style.background='#2a2a2a'"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-12">
        <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-3">CREDENTIALS</p>
        <h2 class="text-4xl font-bold text-gray-900">Our Certifications</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {certifications.map((cert) => (
          <div class="flex items-center gap-4 p-6" style="border:1px solid #e5e7eb;">
            <div class="w-8 h-8 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
              <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="3" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
            </div>
            <span class="text-base font-semibold text-gray-800">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section class="py-16" style="background:#f5f5f5;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200">
        {stats.map((stat) => (
          <div class="bg-white p-10 text-center">
            <div class="flex items-center justify-center gap-1 mb-2">
              <svg class="w-5 h-5" style="color:#F2A93B;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852Z"/>
              </svg>
              <span class="text-5xl font-bold tracking-tight" style="color:#F2A93B;">{stat.number}</span>
            </div>
            <p class="text-base text-gray-500 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</MainLayout>
