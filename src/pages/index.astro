---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import QuoteForm from '../components/QuoteForm.astro';
import content from '../data/content.json';
const { readySection, bestServices, helpSection, services, homepageServiceIds, faq, business } = content;
const homeServices = services.filter(s => homepageServiceIds.includes(s.id));
---

<MainLayout title="ReliableFix Handyman Services | Rochester, NY">

  <!-- 1. HERO -->
  <Hero />

  <!-- 2. SERVICES STRIP: 6 cards, horizontal scroll on mobile, grid on desktop -->
  <section style="background:#0f0f0f; padding: 0 0 48px 0;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">

      <div class="text-center pt-12 mb-10">
        <p class="uppercase text-xs tracking-widest font-semibold mb-3" style="color:#F2A93B;">WHAT WE DO</p>
        <h2 class="text-4xl font-bold text-white">Our Services</h2>
      </div>

      <!-- Scroll container: horizontal on mobile, 3-col grid on desktop -->
      <div class="flex gap-5 overflow-x-auto pb-4 lg:grid lg:grid-cols-3 lg:overflow-visible lg:pb-0 snap-x snap-mandatory lg:snap-none" style="-webkit-overflow-scrolling:touch; scrollbar-width:none;">
        {homeServices.map((svc) => (
          <a
            href={`/services#${svc.id}`}
            class="group flex-shrink-0 w-72 lg:w-auto snap-start overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col"
            style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);"
          >
            <!-- Image -->
            <div class="relative overflow-hidden" style="height:180px;">
              <img
                src={svc.image}
                alt={svc.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                onerror="this.style.background='#2a2a2a'; this.style.display='block';"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              <!-- Yellow bottom bar on hover -->
              <div class="absolute bottom-0 left-0 right-0 h-0.5 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left" style="background:#F2A93B;"></div>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-yellow-400 transition-colors">
                {svc.title}
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed flex-1">
                {svc.shortDescription}
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold mt-4 transition-all group-hover:gap-2" style="color:#F2A93B;">
                Learn More
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/services" class="inline-flex items-center gap-2 font-semibold text-sm transition-colors hover:underline" style="color:#F2A93B;">
          View All Services & Details
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- 3. READY & WAITING TO ASSIST -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">{readySection.eyebrow}</p>
          <h2 class="text-4xl font-bold text-gray-900 mb-8 leading-tight">{readySection.title}</h2>
          <ul class="space-y-5">
            {readySection.bullets.map((bullet) => (
              <li class="flex items-start gap-4">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#F2A93B;">
                  <svg class="w-3 h-3" fill="none" stroke="black" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                </div>
                <span class="text-base leading-relaxed text-gray-600">{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="overflow-hidden">
          <img src={readySection.image} alt="Handyman with tools" class="w-full h-full object-cover" style="min-height:360px; object-position:center;" />
        </div>
      </div>
    </div>
  </section>

  <!-- 4. BEST SERVICES IN TOWN -->
  <section class="py-20" style="background:#f5f5f5;">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="overflow-hidden">
          <img src={bestServices.image} alt="Best handyman services" class="w-full object-cover" style="min-height:400px; object-position:center;" />
        </div>
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">OUR EXPERTISE</p>
          <h2 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">{bestServices.title}</h2>
          <p class="text-base leading-relaxed text-gray-500 mb-8">{bestServices.description}</p>
          <a href={bestServices.ctaHref} style="background:#F2A93B;" class="inline-block text-black font-bold text-sm px-8 py-4 hover:brightness-95 transition-all">
            {bestServices.cta}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. HELP SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-4">HIGHLY EXPERIENCED HANDYMEN</p>
          <h2 class="text-4xl font-bold text-gray-900 mb-4 leading-tight">{helpSection.title}</h2>
          <p class="text-base leading-relaxed text-gray-500 mb-8">{helpSection.description}</p>
          <div class="space-y-4">
            {helpSection.features.map((feat) => (
              <div class="flex items-start gap-4 p-5" style="border:1px solid #e5e7eb;">
                <div class="w-8 h-8 flex items-center justify-center flex-shrink-0" style="background:#F2A93B;">
                  {feat.icon === 'shield' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                  )}
                  {feat.icon === 'certificate' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                  )}
                  {feat.icon === 'clock' && (
                    <svg class="w-4 h-4" fill="none" stroke="black" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  )}
                </div>
                <p class="text-base leading-relaxed text-gray-600">{feat.text}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="overflow-hidden">
          <img src={helpSection.image} alt="Technician at work" class="w-full object-cover" style="min-height:420px; object-position:center;" />
        </div>
      </div>
    </div>
  </section>

  <!-- 6. TESTIMONIALS -->
  <Testimonials />

  <!-- 7. FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">

      <div class="text-center mb-14">
        <p class="uppercase text-xs tracking-widest text-gray-500 font-semibold mb-3">ON CALL ASSIST</p>
        <h2 class="text-4xl font-bold text-gray-900 mb-4">We're Here To Help</h2>
        <p class="text-base text-gray-500 max-w-xl mx-auto">Common questions from Rochester homeowners — answered.</p>
      </div>

      <!-- Trust badges row -->
      <div class="flex flex-wrap justify-center gap-8 mb-12">
        <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
          <svg class="w-5 h-5 flex-shrink-0" style="color:#F2A93B;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          We're never late
        </div>
        <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
          <svg class="w-5 h-5 flex-shrink-0" style="color:#F2A93B;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          Same-Day Response
        </div>
        <div class="flex items-center gap-2 text-gray-600 text-sm font-medium">
          <svg class="w-5 h-5 flex-shrink-0" style="color:#F2A93B;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          Satisfaction Guaranteed
        </div>
      </div>

      <!-- FAQ accordion: 2-col on desktop -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-0 divide-y-0">
        {faq.map((item, i) => (
          <details
            class="group border-t border-gray-200 py-0"
            style={i === faq.length - 1 || i === faq.length - 2 ? 'border-bottom: 1px solid #e5e7eb;' : ''}
          >
            <summary class="flex items-center justify-between cursor-pointer list-none gap-4 py-5">
              <span class="font-semibold text-gray-900 text-base pr-4">{item.question}</span>
              <div class="w-7 h-7 flex items-center justify-center flex-shrink-0 border border-gray-200 group-open:border-yellow-400 transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-500 group-open:rotate-45 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                </svg>
              </div>
            </summary>
            <p class="pb-5 text-gray-500 text-base leading-relaxed max-w-lg">{item.answer}</p>
          </details>
        ))}
      </div>

    </div>
  </section>

  <!-- 8. QUOTE FORM -->
  <QuoteForm />

</MainLayout>
